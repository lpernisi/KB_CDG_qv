<?xml version="1.0" encoding="UTF-8"?>
<!--
  Reverse proxy IIS (ARR + URL Rewrite) -> backend Flask/waitress su http://localhost:8765
  Mettere questo web.config nella ROOT del sito IIS dedicato "CDG_QV" (vedi PUBBLICAZIONE-IIS.md).
  Prerequisiti: moduli "Application Request Routing" e "URL Rewrite" installati,
  e proxy ARR abilitato a livello server (Enable proxy).
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="CDG_QV proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:8765/{R:1}" />
          <serverVariables>
            <!-- informa il backend che a valle e' HTTPS (ProxyFix lo onora) -->
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>
    <!-- timeout/risposte ampie per le query piu' lunghe (es. rilancio ricalcolo) -->
    <proxy xmlns="urn:schemas-microsoft-com:application-request-routing" timeout="00:05:00" />
  </system.webServer>
</configuration>
